5.388 12 12 12 12-5.38 12-12c0-6.612-5.38-12-12-12z" transform="translate(52 0)"></path><path d="M 12 0C5.388 0 0 5.388 0 12s5.388 12 12 12 12-5.38 12-12c0-6.612-5.38-12-12-12z" transform="translate(78 0)"></path><path d="M 12 0C5.388 0 0 5.388 0 12s5.388 12 12 12 12-5.38 12-12c0-6.612-5.38-12-12-12z" transform="translate(104 0)"></path></svg></div></div></div></div><h3 class="biGQs _P SewaP qWPrE ncFvv ezezH" data-automation="review-title"><a target="_blank" tabindex="0" href="/ShowUserReviews-g303506-d25334026-r920729667-Maracana_Stadium_Match_Tickets_with_Welcome_Drink-Rio_de_Janeiro_State_of_Rio_d.html" class="BMQDV _F Gv wSSLS SwZTJ FGwzt ukgoS"><span lang="es"><span class="yCeTE">¡Una experiencia inolvidable!</span></span></a></h3><div class="RpeCd">oct 2023 • Solo</div><div><div class="_T FKffI bmUTE"><div class="fIrGe _T _c bgMZj" style="-webkit-line-clamp:7;line-break:normal;cursor:auto"><div class="biGQs _P VImYz AWdfh"><span class="JguWG"><span lang="es"><span class="yCeTE">Los cánticos, el ambiente, la pasión, fue increíble, ¡se nos puso la piel de gallina! !<br>Sin embargo, pocos comentarios, ¡la reunión previa al juego podría haber sido mejor por el precio del paquete! Quiero decir que el dinero vale la pena, pero es un poco caro ya que, aparte del punto de encuentro, la única cerveza que se ofrece y caminar con seguridad hasta el estadio, ¡el paquete es demasiado alto ya que la entrada al partido es barata! Gustavo, un súper fanático de Fluminese de por vida, nuestro guía, sin embargo, fue muy amable y servicial todo el tiempo.<br>De todos modos, ¡me encantó la experiencia en general! ¡Algo imprescindible que hacer en Río!</span></span></span></div></div><div class="lszDU"><button class="UikNM _G B- _S _W u _T c G_ wSSLS xhwUe utTrc" type="button"><span class="biGQs _P ezezH">Leer más</span><div class="CECjK _W PH"><svg viewBox="0 0 24 24" width="20px" height="20px" class="d Vb UmNoP" aria-hidden="true"><path d="M18.4 7.4 12 13.7 5.6 7.4 4.2 8.8l7.8 7.8 7.8-7.8z"></path></svg></div></button></div></div></div><div></div><div class="TreSq ieLyt"><div class="fZuqm K"><div class=""><span class="Ne d Vm"><span class="biGQs _P VImYz navcl"></span><img alt="Google" src="https://static.tacdn.com/img2/langs/es/branding/partners/powered_by_google_translate.png"/></span></div><span class="yGoeW"><span class="biGQs _P VImYz navcl"><button type="button" class="NsTei">Mostrar original</button></span></span></div><div class="biGQs _P VImYz ncFvv navcl">Escrita el 11 de octubre de 2023</div></div><div class="hjJJO PJ"><div><div class="CXZQW M k MI"><div class="hcVjp f u o"><div class="hzzSG"><div class="MLvbw f u"><div class="AYlYS" style="z-index:0"><div class=""><div class="tknvo ccudK Rb I o"><div class=""><a target="_self" tabindex="-1" aria-hidden="true" href="/Profile/rioasalocal" class="BMQDV _F Gv wSSLS SwZTJ"><div class="BMQDV _F Gv FGwzt VGRsN"><picture class="NhWcC _R afQPz eXZKw" style="width:32px;height:32px"><img src="https://dynamic-media-cdn.tripadvisor.com/media/photo-o/28/56/e6/2c/rio-as-a.jpg?w=100&amp;h=100&amp;s=1" width="100" height="100" alt="" loading="lazy" data-scaled-link-image="true"/></picture></div></a></div></div></div></div></div></div><div class="QIHsu Zb"><span class="biGQs _P ezezH"><a target="_self" href="/Profile/rioasalocal" class="BMQDV _F Gv wSSLS SwZTJ FGwzt ukgoS">Rio As A Local</a></span></div></div><div class="Sgbpo"><div class="_T"><div class="JLKop w"><button class="BrOJk u j z _F _S wSSLS HuPlH Vonfv" type="button" aria-haspopup="menu" aria-label="Abrir menú de opciones"><svg viewBox="0 0 24 24" width="20px" height="20px" class="d Vb UmNoP" aria-hidden="true"><path d="M5 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4m14 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4m-7 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4"></path></svg></button></div></div></div></div><div class="_T FKffI bmUTE"><div class="fIrGe _T _c bgMZj" style="-webkit-line-clamp:3;line-break:normal;cursor:auto"><div class="biGQs _P VImYz AWdfh"><span class="JguWG"><span class="yCeTE">Hi! We are happy you enjoyed the experience with us. Please note that the face value on your ticket does not reflect the actual cost of it- these members-only-section tickets are bought through resellers for a much higher price. We believe this effort is what makes the experience unforgettable. Regards, Bruno.</span></span></div></div><div class="lszDU"><button class="UikNM _G B- _S _W u _T c G_ wSSLS xhwUe utTrc" type="button"><span class="biGQs _P ezezH">Leer más</span><div class="CECjK _W PH"><svg viewBox="0 0 24 24" width="20px" height="20px" class="d Vb UmNoP" aria-hidden="true"><path d="M18.4 7.4 12 13.7 5.6 7.4 4.2 8.8l7.8 7.8 7.8-7.8z"></path></svg></div></button></div></div><div class="biGQs _P VImYz xUqsL ncFvv navcl">Escrita el 13 de marzo de 2024</div></div></div></div></div></div><div data-automation="tab"><hr class="RMdFe jHZoa vfszC"/><div class="C" data-ft="true"><div class="_c" data-automation="reviewCard"><div class="mwPje k"><div><div class="hcVjp f u o"><div class="hzzSG"><div class="MLvbw f u"><div class="AYlYS" style="z-index:0"><div class=""><div class="tknvo ccudK Rb I o"><div class=""><a target="_self" tabindex="-1" aria-hidden="true" href="/Profile/J1295SKangelab" class="BMQDV _F Gv wSSLS SwZTJ"><div class="BMQDV _F Gv FGwzt VGRsN"><picture class="NhWcC _R afQPz eXZKw" style="width:32px;height:32px"><img src="https://dynamic-media-cdn.tripadvisor.com/media/photo-o/1a/f6/f3/23/default-avatar-2020-28.jpg?w=100&amp;h=100&amp;s=1" width="100" height="100" alt="" loading="lazy" data-scaled-link-image="true"/></picture></div></a></div></div></div></div></div></div><div class="QIHsu Zb"><span class="biGQs _P ezezH"><a target="_self" href="/Profile/J1295SKangelab" class="BMQDV _F Gv wSSLS SwZTJ FGwzt ukgoS">Angela B</a></span><div class="vYLts"><div class="biGQs _P navcl"><span>Cave Creek, Arizona</span><span class="IugUm">6 aportes</span></div></div></div></div></div><div class="ZvZJG"><button class="BrOJk u j z _F _S wSSLS HuP